{"type":"item.started","item":{"id":"item_28","type":"command_execution","command":"/usr/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nfrom pathlib import Path\nimport requests, json\nfrom datasets import load_dataset\nPath('datasets').mkdir(exist_ok=True)\n\n# Download MGSM from official repo raw files\nbase='https://raw.githubusercontent.com/google-research/url-nlp/main/mgsm/'\nlangs=['bn','de','en','es','fr','ja','ru','sw','te','th','zh']\nmgsm_dir=Path('datasets/mgsm')\nmgsm_dir.mkdir(parents=True,exist_ok=True)\ncount=0\nfor lg in langs:\n    url=base+f'mgsm_{lg}.tsv'\n    r=requests.get(url,timeout=30)\n    if r.status_code==200 and r.text.strip():\n        (mgsm_dir/f'mgsm_{lg}.tsv').write_text(r.text)\n        count+=1\n    else:\n        print('Missing',url,r.status_code)\nprint('MGSM files downloaded:',count)\n\n# Try SVAMP from HF as additional benchmark\nloaded=False\nfor name in [('ChilleD/SVAMP',None),('svamp',None),('MathArena/svamp',None)]:\n    ds_name,config=name\n    try:\n        ds=load_dataset(ds_name) if config is None else load_dataset(ds_name,config)\n        ds.save_to_disk('datasets/svamp')\n        sdir=Path('datasets/svamp/samples')\n        sdir.mkdir(parents=True,exist_ok=True)\n        sample={k:{'num_rows':len(v),'columns':v.column_names,'first_example':(v[0] if len(v)>0 else {})} for k,v in ds.items()}\n        with open(sdir/'examples.json','w') as f: json.dump(sample,f,indent=2,ensure_ascii=False)\n        print('Loaded SVAMP from',ds_name)\n        loaded=True\n        break\n    except Exception as e:\n        print('SVAMP failed',ds_name,':',str(e)[:120])\nif not loaded:\n    print('SVAMP unavailable')\n\n# MGSM sample creation from TSV\nsamples=[]\nfor f in sorted(mgsm_dir.glob('mgsm_*.tsv')):\n    lines=f.read_text().splitlines()\n    if lines:\n        header=lines[0].split('\\\\t')\n        row=lines[1].split('\\\\t') if len(lines)>1 else []\n        samples.append({'file':f.name,'rows':max(0,len(lines)-1),'header':header,'first_row':row})\n(mgsm_dir/'samples').mkdir(exist_ok=True)\nwith open(mgsm_dir/'samples/examples.json','w') as fo:\n    json.dump(samples,fo,indent=2,ensure_ascii=False)\nprint('Wrote MGSM samples')\nPY\nfind datasets -maxdepth 3 -type f | sed -n '1,120p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
