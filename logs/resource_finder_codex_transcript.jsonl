{"type":"item.started","item":{"id":"item_26","type":"command_execution","command":"/usr/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\nPath('datasets').mkdir(exist_ok=True)\nloaded=[]\n\n# 1) GSM8K\ntry:\n    gsm=load_dataset('openai/gsm8k','main')\n    gsm.save_to_disk('datasets/gsm8k_main')\n    loaded.append(('gsm8k_main',gsm))\n    print('Loaded GSM8K')\nexcept Exception as e:\n    print('GSM8K failed:',e)\n\n# 2) MGSM\nmgsm_variants=['juletxara/mgsm','google-research-datasets/mgsm','mgsm']\nfor name in mgsm_variants:\n    try:\n        ds=load_dataset(name)\n        ds.save_to_disk('datasets/mgsm')\n        loaded.append(('mgsm',ds))\n        print('Loaded MGSM from',name)\n        break\n    except Exception as e:\n        print('MGSM attempt failed',name,':',str(e)[:160])\n\n# 3) Numeracy-style synthetic benchmark: numer_sense if available\nfor name in ['numer_sense','allenai/numer-sense','qiaojin/POLA']:\n    try:\n        ds=load_dataset(name)\n        out='datasets/'+name.replace('/','_')\n        ds.save_to_disk(out)\n        loaded.append((out.split('/')[-1],ds))\n        print('Loaded',name)\n        break\n    except Exception as e:\n        print('Optional dataset attempt failed',name,':',str(e)[:120])\n\n# Validation samples\nfor dsname,ds in loaded:\n    sample={}\n    for split in ds.keys():\n        first=ds[split][0] if len(ds[split])>0 else {}\n        sample[split]={\n            'num_rows':len(ds[split]),\n            'columns':ds[split].column_names,\n            'first_example':first,\n        }\n    sdir=Path('datasets')/dsname/'samples'\n    sdir.mkdir(parents=True,exist_ok=True)\n    with open(sdir/'examples.json','w') as f:\n        json.dump(sample,f,indent=2,ensure_ascii=False)\n    print('Wrote sample for',dsname)\nPY\nls -la datasets\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
